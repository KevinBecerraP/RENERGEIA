@page "/proyectos/{ProyectoId:int}/wbs"
@attribute [Authorize]
@rendermode InteractiveServer
@inject RenergeIADbContext Db
@inject NavigationManager Navigation

<PageTitle>WBS — RenergeIA</PageTitle>

@if (_proyecto is null && !_cargando)
{
    <div class="text-center py-5">
        <h4 class="text-muted">Proyecto no encontrado</h4>
        <a href="/proyectos" class="btn btn-primary mt-3">Volver</a>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <a href="/proyectos/@ProyectoId" class="btn btn-sm btn-outline-secondary">&#8592; Volver</a>
        <div class="flex-grow-1">
            <h2 class="mb-0">WBS — Estructura de Actividades</h2>
            @if (_proyecto is not null)
            {
                <span class="text-muted small">@_proyecto.Nombre</span>
            }
        </div>
        @if (!_cargando && _actividades.Any())
        {
            <div class="form-check form-switch me-2 d-flex align-items-center gap-2 mb-0">
                <input class="form-check-input" type="checkbox" id="mostrarInactivas"
                       @bind="_mostrarInactivas" style="cursor:pointer;" />
                <label class="form-check-label text-muted small" for="mostrarInactivas">
                    Mostrar inactivas
                </label>
            </div>
        }
        @if (!_cargando && !_actividades.Any())
        {
            <button class="btn btn-outline-success" @onclick="() => _confirmarPlantilla = true">
                &#128203; Cargar plantilla
            </button>
        }
        <a href="/proyectos/@ProyectoId/wbs/nueva" class="btn btn-primary">+ Nueva Actividad</a>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger alert-dismissible">
            @_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }

    @if (_confirmarPlantilla)
    {
        <div class="alert border shadow-sm mb-4" style="border-color:#198754!important; background:#f0fff4;">
            <div class="d-flex align-items-start gap-3">
                <span style="font-size:2rem;">&#128203;</span>
                <div class="flex-grow-1">
                    <h5 class="fw-bold mb-1">Cargar plantilla tipo EPC fotovoltaico</h5>
                    <p class="mb-2 text-muted">
                        Se crearán <strong>@_plantilla.Count actividades</strong> predeterminadas basadas en el
                        cronograma tipo Renergeia (proyecto Hato Grande). Las fechas se calcularán automáticamente
                        desde la fecha de inicio planificada del proyecto.
                    </p>
                    <p class="mb-3 text-muted small">
                        Podrás <strong>desactivar</strong> las actividades que no apliquen a este proyecto y
                        <strong>agregar nuevas</strong> manualmente cuando sea necesario.
                    </p>
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-success" @onclick="CargarPlantillaAsync" disabled="@_cargandoPlantilla">
                            @if (_cargandoPlantilla)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Cargando...</span>
                            }
                            else
                            {
                                <span>&#10003; Sí, cargar plantilla</span>
                            }
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="() => _confirmarPlantilla = false"
                                disabled="@_cargandoPlantilla">
                            Cancelar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!_actividades.Any() && !_confirmarPlantilla)
    {
        <div class="text-center py-5">
            <div style="font-size:3.5rem;">&#128203;</div>
            <h5 class="text-muted mt-3">No hay actividades registradas</h5>
            <p class="text-muted">Puedes cargar la plantilla predeterminada del cronograma tipo EPC fotovoltaico,<br/>o crear actividades manualmente una a una.</p>
            <div class="d-flex gap-3 justify-content-center mt-3 flex-wrap">
                <button class="btn btn-success btn-lg" @onclick="() => _confirmarPlantilla = true">
                    &#128203; Cargar plantilla
                </button>
                <a href="/proyectos/@ProyectoId/wbs/nueva" class="btn btn-outline-primary btn-lg">
                    + Nueva actividad manual
                </a>
            </div>
        </div>
    }
    else if (_actividades.Any())
    {
        <!-- Tarjetas resumen -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fw-bold fs-4">@_actividades.Count(a => a.Activo)</div>
                    <div class="text-muted small">Actividades activas</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fw-bold fs-4 text-success">@_actividades.Count(a => a.Estado == EstadoActividad.Completada && a.Activo)</div>
                    <div class="text-muted small">Completadas</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fw-bold fs-4 text-warning">@_actividades.Count(a => a.Estado == EstadoActividad.EnProgreso && a.Activo)</div>
                    <div class="text-muted small">En progreso</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fw-bold fs-4 text-danger">@_actividades.Count(a => (a.Estado == EstadoActividad.Retrasada || a.Estado == EstadoActividad.Bloqueada) && a.Activo)</div>
                    <div class="text-muted small">Con problemas</div>
                </div>
            </div>
        </div>

        @if (!_actividades.Any(a => a.Activo) && !_mostrarInactivas)
        {
            <div class="alert alert-warning text-center">
                Todas las actividades están inactivas. Activa "Mostrar inactivas" para verlas.
            </div>
        }

        <!-- Árbol de actividades -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="min-width:300px;">Actividad</th>
                        <th>Estado</th>
                        <th>Avance real</th>
                        <th>Inicio plan.</th>
                        <th>Fin plan.</th>
                        <th>Responsable</th>
                        <th class="text-center">Activa</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var act in _raicesVisibles)
                    {
                        @RenderActividad(act, 0)
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    [Parameter] public int ProyectoId { get; set; }

    private Proyecto? _proyecto;
    private List<ActividadWBS> _actividades = new();
    private bool _cargando = true;
    private bool _mostrarInactivas;
    private bool _confirmarPlantilla;
    private bool _cargandoPlantilla;
    private string? _error;

    private IEnumerable<ActividadWBS> _raicesVisibles => _actividades
        .Where(a => a.ActividadPadreId is null && (_mostrarInactivas || a.Activo));

    protected override async Task OnInitializedAsync()
    {
        _proyecto = await Db.Proyectos.FindAsync(ProyectoId);
        if (_proyecto is not null)
            await CargarActividadesAsync();
        _cargando = false;
    }

    private async Task CargarActividadesAsync()
    {
        var lista = await Db.ActividadesWBS
            .Where(a => a.ProyectoId == ProyectoId)
            .ToListAsync();

        _actividades = lista
            .OrderBy(a => WbsSortKey(a.CodigoWBS))
            .ToList();
    }

    // Convierte "1.10" → "0001.0010" para ordenar numéricamente
    private static string WbsSortKey(string codigo) =>
        string.Join(".", codigo.Split('.').Select(p => p.PadLeft(4, '0')));

    private async Task ToggleActivoAsync(int id, bool nuevoValor)
    {
        var act = await Db.ActividadesWBS.FindAsync(id);
        if (act is null) return;
        act.Activo = nuevoValor;
        await Db.SaveChangesAsync();
        // Reflect change in local list to avoid full reload
        var local = _actividades.FirstOrDefault(a => a.Id == id);
        if (local is not null) local.Activo = nuevoValor;
    }

    private async Task CargarPlantillaAsync()
    {
        if (_proyecto is null) return;
        _cargandoPlantilla = true;
        _error = null;

        try
        {
            var fechaInicio = _proyecto.FechaInicioPlanificada;
            var idMap = new Dictionary<string, int>();

            // Insert level by level so parent IDs are available for children
            for (int nivel = 1; nivel <= 4; nivel++)
            {
                var batch = _plantilla.Where(p => p.Nivel == nivel).ToList();
                if (!batch.Any()) continue;

                var entities = new List<(string Codigo, ActividadWBS Entity)>();
                foreach (var item in batch)
                {
                    int? padreId = item.CodigoPadre is not null && idMap.TryGetValue(item.CodigoPadre, out var pid)
                        ? pid : null;

                    var act = new ActividadWBS
                    {
                        ProyectoId             = ProyectoId,
                        CodigoWBS              = item.Codigo,
                        Nombre                 = item.Nombre,
                        NivelWBS               = item.Nivel,
                        Descripcion            = string.Empty,
                        Responsable            = string.Empty,
                        Activo                 = true,
                        ActividadPadreId       = padreId,
                        FechaInicioPlanificada = fechaInicio.AddDays(item.DiasDesdeInicio),
                        FechaFinPlanificada    = fechaInicio.AddDays(item.DiasDesdeInicio + (item.DuracionDias > 0 ? item.DuracionDias : 1)),
                        AvancePlanificado      = 0,
                        AvanceReal             = 0,
                        Estado                 = EstadoActividad.Pendiente,
                        Disciplina             = item.Disciplina,
                        FechaCreacion          = DateTime.UtcNow
                    };
                    Db.ActividadesWBS.Add(act);
                    entities.Add((item.Codigo, act));
                }

                await Db.SaveChangesAsync();

                // After SaveChanges, EF Core has populated the Ids
                foreach (var (codigo, entity) in entities)
                    idMap[codigo] = entity.Id;
            }

            await CargarActividadesAsync();
            _confirmarPlantilla = false;
            _mostrarInactivas = false;
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar la plantilla: {ex.Message}";
        }
        finally
        {
            _cargandoPlantilla = false;
        }
    }

    private RenderFragment RenderActividad(ActividadWBS act, int nivel) => __builder =>
    {
        var hijosVisibles = _actividades
            .Where(a => a.ActividadPadreId == act.Id && (_mostrarInactivas || a.Activo))
            .ToList();
        var indentPx = nivel * 22;
        var opacityStyle = act.Activo ? "" : "opacity:.45;";

        <tr style="@opacityStyle">
            <td>
                <div style="padding-left:@(indentPx)px;" class="d-flex align-items-center gap-2">
                    @if (_actividades.Any(a => a.ActividadPadreId == act.Id))
                    {
                        <span class="text-muted" style="font-size:.8rem;">&#9660;</span>
                    }
                    else
                    {
                        <span style="display:inline-block;width:14px;"></span>
                    }
                    <div>
                        <span class="badge bg-secondary me-1" style="font-size:.7rem;">@act.CodigoWBS</span>
                        <span class="@(nivel == 0 ? "fw-bold" : "")">@act.Nombre</span>
                    </div>
                </div>
            </td>
            <td>
                @if (act.Activo)
                {
                    <span class="badge @BadgeEstado(act.Estado)">@NombreEstado(act.Estado)</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactiva</span>
                }
            </td>
            <td>
                @if (act.Activo)
                {
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height:6px; min-width:60px;">
                            <div class="progress-bar @ColorProgreso(act.AvanceReal)"
                                 style="width:@(act.AvanceReal)%;"></div>
                        </div>
                        <span class="small text-muted">@act.AvanceReal%</span>
                    </div>
                }
                else
                {
                    <span class="text-muted small">—</span>
                }
            </td>
            <td class="small text-muted">@act.FechaInicioPlanificada.ToString("dd/MM/yy")</td>
            <td class="small text-muted">@act.FechaFinPlanificada.ToString("dd/MM/yy")</td>
            <td class="small">@(string.IsNullOrEmpty(act.Responsable) ? "—" : act.Responsable)</td>
            <td class="text-center">
                <button class="btn btn-sm @(act.Activo ? "btn-success" : "btn-outline-secondary")"
                        style="min-width:70px; font-size:.75rem; padding:2px 8px;"
                        @onclick="() => ToggleActivoAsync(act.Id, !act.Activo)"
                        title="@(act.Activo ? "Desactivar" : "Activar")">
                    @(act.Activo ? "✓ Activa" : "Inactiva")
                </button>
            </td>
            <td>
                @if (act.Activo)
                {
                    <div class="d-flex gap-1">
                        <a href="/proyectos/@ProyectoId/wbs/@act.Id/editar"
                           class="btn btn-sm btn-outline-primary">Editar</a>
                        <a href="/proyectos/@ProyectoId/wbs/nueva?padreId=@act.Id"
                           class="btn btn-sm btn-outline-secondary" title="Agregar subactividad">+Sub</a>
                    </div>
                }
            </td>
        </tr>

        @foreach (var hijo in hijosVisibles)
        {
            @RenderActividad(hijo, nivel + 1)
        }
    };

    private static string BadgeEstado(EstadoActividad e) => e switch
    {
        EstadoActividad.Pendiente  => "bg-secondary",
        EstadoActividad.EnProgreso => "bg-primary",
        EstadoActividad.Completada => "bg-success",
        EstadoActividad.Retrasada  => "bg-danger",
        EstadoActividad.Bloqueada  => "bg-warning text-dark",
        _                          => "bg-secondary"
    };

    private static string NombreEstado(EstadoActividad e) => e switch
    {
        EstadoActividad.Pendiente  => "Pendiente",
        EstadoActividad.EnProgreso => "En progreso",
        EstadoActividad.Completada => "Completada",
        EstadoActividad.Retrasada  => "Retrasada",
        EstadoActividad.Bloqueada  => "Bloqueada",
        _                          => e.ToString()
    };

    private static string ColorProgreso(decimal avance) => avance switch
    {
        >= 100 => "bg-success",
        >= 60  => "bg-primary",
        >= 30  => "bg-warning",
        _      => "bg-danger"
    };

