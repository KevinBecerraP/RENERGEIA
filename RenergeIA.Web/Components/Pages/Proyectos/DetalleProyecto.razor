@page "/proyectos/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject RenergeIADbContext Db
@inject NavigationManager Navigation

<PageTitle>@(_proyecto?.Nombre ?? "Proyecto") — RenergeIA</PageTitle>

@if (_cargando)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (_proyecto is null)
{
    <div class="text-center py-5">
        <h4 class="text-muted">Proyecto no encontrado</h4>
        <a href="/proyectos" class="btn btn-primary mt-3">Volver a Proyectos</a>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <a href="/proyectos" class="btn btn-sm btn-outline-secondary">&#8592; Volver</a>
        <div class="flex-grow-1">
            <h2 class="mb-0">@_proyecto.Nombre</h2>
            <span class="text-muted small">@_proyecto.Codigo</span>
        </div>
        <span class="badge @BadgeEstado(_proyecto.Estado)">@NombreEstado(_proyecto.Estado)</span>
        <a href="/proyectos/@Id/editar" class="btn btn-sm btn-outline-primary">Editar</a>
        <button class="btn btn-sm btn-outline-danger" @onclick="() => _confirmarEliminar = true">
            Eliminar
        </button>
    </div>

    @if (_confirmarEliminar)
    {
        <div class="alert alert-danger d-flex align-items-center gap-3 mb-4">
            <span>¿Seguro que deseas eliminar el proyecto <strong>@_proyecto.Nombre</strong>? Esta acción no se puede deshacer.</span>
            <div class="d-flex gap-2 ms-auto">
                <button class="btn btn-danger btn-sm" @onclick="EliminarAsync" disabled="@_eliminando">
                    @if (_eliminando)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Sí, eliminar
                </button>
                <button class="btn btn-secondary btn-sm" @onclick="() => _confirmarEliminar = false">
                    Cancelar
                </button>
            </div>
        </div>
    }

    <div class="row g-4">
        <!-- Info general -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header fw-bold" style="background: #1b2838; color: white;">
                    Información General
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Cliente</dt>
                        <dd class="col-sm-7">@_proyecto.Cliente</dd>

                        <dt class="col-sm-5 text-muted">Ubicación</dt>
                        <dd class="col-sm-7">@_proyecto.Ubicacion, @_proyecto.Pais</dd>

                        <dt class="col-sm-5 text-muted">Capacidad</dt>
                        <dd class="col-sm-7">@_proyecto.CapacidadKWp kWp</dd>

                        <dt class="col-sm-5 text-muted">Presupuesto</dt>
                        <dd class="col-sm-7">@_proyecto.PresupuestoContractual.ToString("N0") COP</dd>

                        <dt class="col-sm-5 text-muted">Descripción</dt>
                        <dd class="col-sm-7">@(string.IsNullOrEmpty(_proyecto.Descripcion) ? "—" : _proyecto.Descripcion)</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Cronograma -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header fw-bold" style="background: #1b2838; color: white;">
                    Cronograma
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6 text-muted">Inicio planificado</dt>
                        <dd class="col-sm-6">@_proyecto.FechaInicioPlanificada.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-6 text-muted">Fin planificado</dt>
                        <dd class="col-sm-6">@_proyecto.FechaFinPlanificada.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-6 text-muted">Inicio real</dt>
                        <dd class="col-sm-6">@(_proyecto.FechaInicioReal?.ToString("dd/MM/yyyy") ?? "—")</dd>

                        <dt class="col-sm-6 text-muted">Fin real</dt>
                        <dd class="col-sm-6">@(_proyecto.FechaFinReal?.ToString("dd/MM/yyyy") ?? "—")</dd>

                        <dt class="col-sm-6 text-muted">Duración planificada</dt>
                        <dd class="col-sm-6">@((_proyecto.FechaFinPlanificada - _proyecto.FechaInicioPlanificada).Days) días</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Módulos del proyecto -->
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header fw-bold" style="background: #1b2838; color: white;">
                    Módulos del Proyecto
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var modulo in _modulos)
                        {
                            <div class="col-md-3 col-sm-6">
                                @if (modulo.Disponible && modulo.Url is not null)
                                {
                                    <a href="@modulo.Url" class="text-decoration-none">
                                        <div class="card border text-center p-3 h-100 shadow-sm" style="cursor:pointer; transition: box-shadow .15s;">
                                            <div style="font-size: 2rem;">@modulo.Icono</div>
                                            <div class="fw-semibold small mt-1">@modulo.Nombre</div>
                                            <div class="text-primary" style="font-size: 0.7rem;">Ver &rsaquo;</div>
                                        </div>
                                    </a>
                                }
                                else
                                {
                                    <div class="card border text-center p-3 h-100 opacity-50">
                                        <div style="font-size: 2rem;">@modulo.Icono</div>
                                        <div class="fw-semibold small mt-1">@modulo.Nombre</div>
                                        <div class="text-muted" style="font-size: 0.7rem;">Próximamente</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Proyecto? _proyecto;
    private bool _cargando = true;
    private bool _confirmarEliminar;
    private bool _eliminando;

    private List<(string Nombre, string Icono, bool Disponible, string? Url)> _modulos = new();

    protected override async Task OnInitializedAsync()
    {
        _proyecto = await Db.Proyectos.FindAsync(Id);
        _modulos =
        [
            ("Personal",           "👷", true,  $"/proyectos/{Id}/personal"),
            ("Equipos",            "⚙️",  true,  $"/proyectos/{Id}/equipos"),
            ("WBS / Actividades",  "📄", true,  $"/proyectos/{Id}/wbs"),
            ("Informe Diario",     "📋", true,  $"/informes-diarios/{Id}"),
            ("Documentos",         "📁", true,  $"/documentos/{Id}"),
            ("Costos",             "💰", false, null),
            ("No Conformidades",   "🚩", false, null),
            ("Restricciones",      "🚫", false, null),
        ];
        _cargando = false;
    }

    private async Task EliminarAsync()
    {
        _eliminando = true;
        var proyecto = await Db.Proyectos.FindAsync(Id);
        if (proyecto is not null)
        {
            Db.Proyectos.Remove(proyecto);
            await Db.SaveChangesAsync();
        }
        Navigation.NavigateTo("/proyectos");
    }

    private static string BadgeEstado(EstadoProyecto estado) => estado switch
    {
        EstadoProyecto.Planificacion => "bg-secondary",
        EstadoProyecto.EnEjecucion   => "bg-success",
        EstadoProyecto.Suspendido    => "bg-warning text-dark",
        EstadoProyecto.Completado    => "bg-primary",
        EstadoProyecto.Cancelado     => "bg-danger",
        _                            => "bg-secondary"
    };

    private static string NombreEstado(EstadoProyecto estado) => estado switch
    {
        EstadoProyecto.Planificacion => "Planificación",
        EstadoProyecto.EnEjecucion   => "En Ejecución",
        EstadoProyecto.Suspendido    => "Suspendido",
        EstadoProyecto.Completado    => "Completado",
        EstadoProyecto.Cancelado     => "Cancelado",
        _                            => estado.ToString()
    };
}
