@page "/proyectos/{ProyectoId:int}/histogramas"
@rendermode InteractiveServer
@inject RenergeIADbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject RenergeIA.Web.Services.HistogramaService HistogramaService
@using Microsoft.EntityFrameworkCore
@using RenergeIA.Core.Entities
@using RenergeIA.Core.Enums
@using RenergeIA.Infrastructure.Data

<PageTitle>Histogramas - @(_proyecto?.Nombre ?? "Proyecto") - RenergeIA</PageTitle>

<div class="container-fluid py-4">
    <!-- Encabezado con gradiente -->
    <div class="row mb-4">
        <div class="col">
            <div class="p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <h2 class="text-white mb-2">
                    <i class="bi bi-bar-chart-fill"></i> Histogramas del Proyecto
                </h2>
                @if (_proyecto is not null)
                {
                    <p class="text-white mb-0 opacity-90">
                        <strong>@_proyecto.Codigo - @_proyecto.Nombre</strong> | Capacidad: @_proyecto.CapacidadKWp kWp (@((_proyecto.CapacidadKWp / 1000m).ToString("0.0")) MW)
                    </p>
                }
            </div>
        </div>
        <div class="col-auto d-flex align-items-center">
            <a href="/proyectos/@ProyectoId" class="btn btn-light shadow-sm">
                <i class="bi bi-arrow-left"></i> Volver al Proyecto
            </a>
        </div>
    </div>

    @if (_cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Cargando histogramas...</p>
        </div>
    }
    else if (_proyecto is null)
    {
        <div class="alert alert-warning">
            <strong>⚠️ Proyecto no encontrado</strong>
        </div>
    }
    else
    {
        <!-- Pestañas Personal / Equipos con diseño moderno -->
        <div class="d-flex gap-3 mb-4">
            <button class="btn flex-fill py-3 shadow-sm @(_tipoSeleccionado == TipoHistograma.Personal ? "btn-gradient-primary" : "btn-outline-primary")"
                    style="border-radius: 15px; font-weight: 600; transition: all 0.3s;"
                    @onclick="() => CambiarTipo(TipoHistograma.Personal)">
                <i class="bi bi-people-fill fs-4 d-block mb-2"></i>
                Personal
            </button>
            <button class="btn flex-fill py-3 shadow-sm @(_tipoSeleccionado == TipoHistograma.Equipos ? "btn-gradient-success" : "btn-outline-success")"
                    style="border-radius: 15px; font-weight: 600; transition: all 0.3s;"
                    @onclick="() => CambiarTipo(TipoHistograma.Equipos)">
                <i class="bi bi-tools fs-4 d-block mb-2"></i>
                Equipos
            </button>
        </div>

        <style>
            .btn-gradient-primary {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                border: none;
            }
            .btn-gradient-primary:hover {
                background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
                color: white;
                transform: translateY(-2px);
            }
            .btn-gradient-success {
                background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
                color: white;
                border: none;
            }
            .btn-gradient-success:hover {
                background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);
                color: white;
                transform: translateY(-2px);
            }
        </style>

        @if (_plantillaActual is not null && _items.Any())
        {
            <!-- Info de plantilla con diseño moderno -->
            <div class="mb-4 p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);">
                <div class="d-flex align-items-center gap-4 flex-wrap">
                    <div>
                        <i class="bi bi-clipboard-data fs-1" style="color: #ff6b6b;"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="mb-1" style="color: #2d3436;">
                            <strong>@_plantillaActual.Nombre</strong>
                        </h5>
                        <p class="mb-0" style="color: #636e72;">
                            <span class="badge bg-danger me-2">@_plantillaActual.CapacidadMW MW</span>
                            <span class="badge bg-dark">@_items.Count items</span>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Gráfico de área con diseño moderno -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow border-0 rounded-4 overflow-hidden">
                        <div class="card-header p-4" style="background: linear-gradient(135deg, @(_tipoSeleccionado == TipoHistograma.Personal ? "#667eea 0%, #764ba2 100%" : "#f093fb 0%, #f5576c 100%"));">
                            <h5 class="mb-0 text-white fw-bold">
                                <i class="bi bi-graph-up-arrow"></i> Distribución Mensual - @(_tipoSeleccionado == TipoHistograma.Personal ? "Personal" : "Equipos")
                            </h5>
                        </div>
                        <div class="card-body p-4" style="background: linear-gradient(to bottom, #f8f9ff 0%, #ffffff 100%);">
                            <div style="height: 450px;">
                                <canvas id="histogramaChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla detallada con diseño moderno -->
            <div class="row">
                <div class="col-12">
                    <div class="card shadow border-0 rounded-4 overflow-hidden">
                        <div class="card-header p-4" style="background: linear-gradient(135deg, @(_tipoSeleccionado == TipoHistograma.Personal ? "#667eea 0%, #764ba2 100%" : "#f093fb 0%, #f5576c 100%"));">
                            <h5 class="mb-0 text-white fw-bold">
                                <i class="bi bi-table"></i> Detalle por @(_tipoSeleccionado == TipoHistograma.Personal ? "Cargo" : "Equipo")
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="sticky-top" style="background: linear-gradient(135deg, #f8f9ff 0%, #e9ecef 100%);">
                                        <style>
                                            .table thead th {
                                                border-bottom: 3px solid @(_tipoSeleccionado == TipoHistograma.Personal ? "#667eea" : "#f5576c") !important;
                                                font-weight: 700;
                                                color: #2d3436;
                                                padding: 1rem 0.5rem;
                                            }
                                            .table tbody tr:hover {
                                                background: linear-gradient(90deg, @(_tipoSeleccionado == TipoHistograma.Personal ? "rgba(102, 126, 234, 0.1)" : "rgba(245, 87, 108, 0.1)") 0%, transparent 100%);
                                            }
                                        </style>
                                        <tr>
                                            <th style="width: 15%">@(_tipoSeleccionado == TipoHistograma.Personal ? "Cargo" : "Equipo")</th>
                                            <th style="width: 20%">Actividad</th>
                                            <th class="text-center" style="width: 5%">Tiempo</th>
                                            @for (int i = 1; i <= 12; i++)
                                            {
                                                <th class="text-center" style="width: 4%">@i</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in _items)
                                        {
                                            <tr>
                                                <td class="small">
                                                    <strong>@item.Cargo</strong>
                                                    @if (!string.IsNullOrEmpty(item.CodigoCargo))
                                                    {
                                                        <br /><code class="small text-muted">@item.CodigoCargo</code>
                                                    }
                                                </td>
                                                <td class="small">@item.Actividad</td>
                                                <td class="text-center">
                                                    <span class="badge bg-secondary">@item.TiempoMeses.ToString("0.0") m</span>
                                                </td>
                                                <td class="text-center @(item.Mes1 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes1)</td>
                                                <td class="text-center @(item.Mes2 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes2)</td>
                                                <td class="text-center @(item.Mes3 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes3)</td>
                                                <td class="text-center @(item.Mes4 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes4)</td>
                                                <td class="text-center @(item.Mes5 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes5)</td>
                                                <td class="text-center @(item.Mes6 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes6)</td>
                                                <td class="text-center @(item.Mes7 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes7)</td>
                                                <td class="text-center @(item.Mes8 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes8)</td>
                                                <td class="text-center @(item.Mes9 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes9)</td>
                                                <td class="text-center @(item.Mes10 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes10)</td>
                                                <td class="text-center @(item.Mes11 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes11)</td>
                                                <td class="text-center @(item.Mes12 > 0 ? "celda-activa" : "")">@FormatearValor(item.Mes12)</td>
                                                <style>
                                                    .celda-activa {
                                                        background: @(_tipoSeleccionado == TipoHistograma.Personal
                                                            ? "linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.3) 100%)"
                                                            : "linear-gradient(135deg, rgba(240, 147, 251, 0.2) 0%, rgba(245, 87, 108, 0.3) 100%)") !important;
                                                        font-weight: 600;
                                                        color: @(_tipoSeleccionado == TipoHistograma.Personal ? "#667eea" : "#f5576c") !important;
                                                    }
                                                </style>
                                            </tr>
                                        }
                                        <!-- Fila de totales con gradiente -->
                                        <tr class="fw-bold" style="background: linear-gradient(135deg, @(_tipoSeleccionado == TipoHistograma.Personal ? "#667eea 0%, #764ba2 100%" : "#f093fb 0%, #f5576c 100%")); color: white;">
                                            <td colspan="3" class="text-end py-3">
                                                <i class="bi bi-calculator"></i> TOTAL POR MES:
                                            </td>
                                            @foreach (var total in _totalesPorMes.OrderBy(kvp => kvp.Key))
                                            {
                                                <td class="text-center py-3">
                                                    <span class="badge bg-white" style="color: @(_tipoSeleccionado == TipoHistograma.Personal ? "#667eea" : "#f5576c"); font-size: 0.9rem;">
                                                        @total.Value.ToString("0.0")
                                                    </span>
                                                </td>
                                            }
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <strong>ℹ️ No hay datos de histogramas</strong>
                <p class="mb-0">No se encontraron plantillas de histogramas para este proyecto.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int ProyectoId { get; set; }

    private Proyecto? _proyecto;
    private bool _cargando = true;
    private TipoHistograma _tipoSeleccionado = TipoHistograma.Personal;
    private PlantillaHistograma? _plantillaActual;
    private List<ItemHistograma> _items = new();
    private Dictionary<int, decimal> _totalesPorMes = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _proyecto = await Db.Proyectos.FindAsync(ProyectoId);
            if (_proyecto is null)
            {
                return;
            }

            await CargarHistogramaAsync();
        }
        finally
        {
            _cargando = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _proyecto is not null && _items.Any())
        {
            await Task.Delay(100);
            await RenderizarGraficoAsync();
        }
    }

    private async Task CambiarTipo(TipoHistograma nuevoTipo)
    {
        _tipoSeleccionado = nuevoTipo;
        await CargarHistogramaAsync();
        await RenderizarGraficoAsync();
    }

    private async Task CargarHistogramaAsync()
    {
        if (_proyecto is null) return;

        var capacidadMW = _proyecto.CapacidadKWp / 1000m;

        _plantillaActual = await HistogramaService.ObtenerPlantillaPorCapacidadAsync(capacidadMW, _tipoSeleccionado);

        if (_plantillaActual is not null)
        {
            _items = await HistogramaService.ObtenerItemsPlantillaAsync(_plantillaActual.Id);
            _totalesPorMes = await HistogramaService.CalcularTotalesPorMesAsync(_plantillaActual.Id);
        }
        else
        {
            _items.Clear();
            _totalesPorMes.Clear();
        }
    }

    private async Task RenderizarGraficoAsync()
    {
        if (_plantillaActual is null || !_items.Any())
            return;

        try
        {
            var datosGrafico = await HistogramaService.GenerarDatosGraficoAsync(_plantillaActual.Id);

            var labels = datosGrafico.Labels;
            var datasets = datosGrafico.Series.Select((s, idx) => new
            {
                label = s.Nombre,
                data = s.Valores.Select(v => (double)v).ToArray(),
                backgroundColor = ObtenerColor(idx, 0.6),
                borderColor = ObtenerColor(idx, 1),
                borderWidth = 1,
                fill = true
            }).ToArray();

            await JS.InvokeVoidAsync("createStackedAreaChart", "histogramaChart", labels, datasets);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al renderizar gráfico: {ex.Message}");
        }
    }

    private string FormatearValor(decimal valor)
    {
        return valor == 0 ? "-" : valor.ToString("0.#");
    }

    private string ObtenerColor(int index, double opacity)
    {
        // Paleta ultra vibrante y moderna
        var colores = new[]
        {
            $"rgba(138, 43, 226, {opacity})",   // Violeta eléctrico
            $"rgba(255, 20, 147, {opacity})",   // Rosa neón
            $"rgba(0, 255, 127, {opacity})",    // Verde primavera
            $"rgba(255, 140, 0, {opacity})",    // Naranja oscuro
            $"rgba(30, 144, 255, {opacity})",   // Azul dodger
            $"rgba(255, 215, 0, {opacity})",    // Dorado brillante
            $"rgba(255, 69, 0, {opacity})",     // Rojo naranja
            $"rgba(64, 224, 208, {opacity})",   // Turquesa brillante
            $"rgba(238, 130, 238, {opacity})",  // Violeta
            $"rgba(50, 205, 50, {opacity})",    // Verde lima
            $"rgba(255, 165, 0, {opacity})",    // Naranja
            $"rgba(123, 104, 238, {opacity})",  // Azul medio
        };

        return colores[index % colores.Length];
    }
}
