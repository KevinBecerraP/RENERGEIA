@page "/informes-diarios/{ProyectoId:int}/crear"
@page "/informes-diarios/{ProyectoId:int}/editar/{InformeId:int}"
@rendermode InteractiveServer
@inject RenergeIADbContext Db
@inject NavigationManager Nav
@inject RenergeIA.Web.Services.InformeDiarioService InformeService
@using Microsoft.EntityFrameworkCore
@using RenergeIA.Core.Entities
@using RenergeIA.Core.Enums
@using RenergeIA.Infrastructure.Data

<PageTitle>@(_esEdicion ? "Editar" : "Crear") Informe Diario - RenergeIA</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2>@(_esEdicion ? "✏️ Editar" : "➕ Crear") Informe Diario</h2>
            @if (_proyecto is not null)
            {
                <p class="text-muted mb-0">Proyecto: <strong>@_proyecto.Codigo - @_proyecto.Nombre</strong></p>
            }
        </div>
        <div class="col-auto">
            <a href="/informes-diarios/@ProyectoId" class="btn btn-outline-secondary">
                ← Volver a la lista
            </a>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }

    @if (_cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border"></div>
            <p class="mt-2 text-muted">Cargando actividades...</p>
        </div>
    }
    else
    {
        <EditForm Model="_informe" OnValidSubmit="GuardarAsync" FormName="FormInforme">
            <div class="row g-4">
                <!-- Información General -->
                <div class="col-md-12">
                    <div class="card shadow-sm">
                        <div class="card-header" style="background: #1b2838; color: white;">
                            <h5 class="mb-0">📋 Información General</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Fecha del Informe *</label>
                                    <InputDate @bind-Value="_informe.Fecha" class="form-control" @bind-Value:after="RecalcularAvancesProgramados" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Nro. Certificado *</label>
                                    <InputText @bind-Value="_informe.NumeroCertificado" class="form-control" placeholder="Ej: CERT-2026-001" required />
                                    <small class="form-text text-muted">Debe ser único en el proyecto</small>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Personal Total</label>
                                    <InputNumber @bind-Value="_informe.PersonalTotal" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Estado</label>
                                    <InputSelect @bind-Value="_informe.Estado" class="form-select">
                                        @foreach (var estado in Enum.GetValues<EstadoInforme>())
                                        {
                                            <option value="@estado">@ObtenerTextoEstado(estado)</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">Resumen de Actividades</label>
                                    <InputTextArea @bind-Value="_informe.ResumenActividades" class="form-control" rows="3" placeholder="Breve resumen de las actividades del día..." />
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">Observaciones Generales</label>
                                    <InputTextArea @bind-Value="_informe.Observaciones" class="form-control" rows="2" />
                                </div>
                                @if (_esEdicion)
                                {
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold">¿Qué cambió en esta versión? (Opcional)</label>
                                        <InputTextArea @bind-Value="_informe.ComentarioCambio" class="form-control" rows="2" placeholder="Ej: Agregué actividad X, corregí cantidad de personal..." />
                                        <small class="form-text text-muted">Esto ayuda a entender el historial de cambios</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Avances del Día - TABLA AUTOMÁTICA -->
                <div class="col-md-12">
                    <div class="card shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-center" style="background: #1b2838; color: white;">
                            <h5 class="mb-0">📊 Avances del Día (@_actividadesConAvance.Count actividades)</h5>
                            <div class="d-flex gap-2">
                                <span class="badge bg-success">@_actividadesConAvance.Count(@a => a.Estado == EstadoAvance.Adelantado) Adelantadas</span>
                                <span class="badge bg-warning text-dark">@_actividadesConAvance.Count(@a => a.Estado == EstadoAvance.AlDia) Al Día</span>
                                <span class="badge bg-danger">@_actividadesConAvance.Count(@a => a.Estado == EstadoAvance.Atrasado) Atrasadas</span>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            @if (!_actividadesConAvance.Any())
                            {
                                <div class="alert alert-info m-3">
                                    <strong>ℹ️ No hay actividades en el WBS</strong>
                                    <p class="mb-0">Primero debes crear actividades en el módulo WBS del proyecto.</p>
                                    <a href="/proyectos/@ProyectoId/wbs" class="btn btn-sm btn-primary mt-2">Ir a WBS</a>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover table-sm mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width:8%">Código WBS</th>
                                                <th style="width:20%">Actividad</th>
                                                <th style="width:8%">Disciplina</th>
                                                <th style="width:8%">Inicio</th>
                                                <th style="width:8%">Fin</th>
                                                <th style="width:6%" class="text-center">Duración</th>
                                                <th style="width:8%" class="text-center bg-light">
                                                    <span class="text-muted small">Programado %</span>
                                                </th>
                                                <th style="width:10%" class="text-center bg-warning bg-opacity-10">
                                                    <span class="fw-bold small">Avance Real %</span>
                                                </th>
                                                <th style="width:8%" class="text-center bg-light">
                                                    <span class="text-muted small">Desviación</span>
                                                </th>
                                                <th style="width:6%" class="text-center">Personal</th>
                                                <th style="width:6%" class="text-center">Horas</th>
                                                <th style="width:4%" class="text-center">Estado</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in _actividadesConAvance)
                                            {
                                                <tr>
                                                    <td class="small align-middle"><code>@item.Actividad.CodigoWBS</code></td>
                                                    <td class="small align-middle">@item.Actividad.Nombre</td>
                                                    <td class="small align-middle">@ObtenerIconoDisciplina(item.Actividad.Disciplina)</td>
                                                    <td class="small align-middle">@item.Actividad.FechaInicioPlanificada.ToString("dd/MM/yy")</td>
                                                    <td class="small align-middle">@item.Actividad.FechaFinPlanificada.ToString("dd/MM/yy")</td>
                                                    <td class="small text-center align-middle">@((item.Actividad.FechaFinPlanificada - item.Actividad.FechaInicioPlanificada).Days)d</td>

                                                    <!-- Avance Programado (CALCULADO - READ ONLY) -->
                                                    <td class="text-center align-middle bg-light">
                                                        <span class="badge bg-secondary">@item.AvanceProgramado.ToString("0.00")%</span>
                                                    </td>

                                                    <!-- Avance Real (ÚNICO CAMPO EDITABLE) -->
                                                    <td class="text-center align-middle bg-warning bg-opacity-10">
                                                        <input type="number"
                                                               @bind="item.AvanceReal"
                                                               @bind:after="() => RecalcularDesviacion(item)"
                                                               class="form-control form-control-sm text-center fw-bold"
                                                               min="0"
                                                               max="100"
                                                               step="0.01"
                                                               style="max-width: 80px; margin: 0 auto;" />
                                                    </td>

                                                    <!-- Desviación (CALCULADA - READ ONLY) -->
                                                    <td class="text-center align-middle bg-light">
                                                        <span class="badge @ObtenerClaseDesviacion(item.Desviacion)">
                                                            @(item.Desviacion >= 0 ? "+" : "")@item.Desviacion.ToString("0.00")%
                                                        </span>
                                                    </td>

                                                    <!-- Campos opcionales -->
                                                    <td class="text-center align-middle">
                                                        <input type="number"
                                                               @bind="item.PersonalEnSitio"
                                                               class="form-control form-control-sm text-center"
                                                               min="0"
                                                               style="max-width: 60px; margin: 0 auto;" />
                                                    </td>
                                                    <td class="text-center align-middle">
                                                        <input type="number"
                                                               @bind="item.HorasTrabajadas"
                                                               class="form-control form-control-sm text-center"
                                                               min="0"
                                                               step="0.5"
                                                               style="max-width: 60px; margin: 0 auto;" />
                                                    </td>

                                                    <!-- Estado (CALCULADO - READ ONLY) -->
                                                    <td class="text-center align-middle">
                                                        <span style="font-size: 1.2rem;" title="@item.Estado">
                                                            @ObtenerIconoEstado(item.Estado)
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Resumen general -->
                                <div class="card-footer bg-light">
                                    <div class="row text-center">
                                        <div class="col">
                                            <div class="small text-muted">Avance Programado Promedio</div>
                                            <div class="h5 mb-0">@_actividadesConAvance.Average(a => a.AvanceProgramado).ToString("0.00")%</div>
                                        </div>
                                        <div class="col">
                                            <div class="small text-muted">Avance Real Promedio</div>
                                            <div class="h5 mb-0">@_actividadesConAvance.Average(a => a.AvanceReal).ToString("0.00")%</div>
                                        </div>
                                        <div class="col">
                                            <div class="small text-muted">Desviación Promedio</div>
                                            <div class="h5 mb-0 @(_actividadesConAvance.Average(a => a.Desviacion) >= 0 ? "text-success" : "text-danger")">
                                                @(_actividadesConAvance.Average(a => a.Desviacion) >= 0 ? "+" : "")@_actividadesConAvance.Average(a => a.Desviacion).ToString("0.00")%
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="col-md-12">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg" disabled="@(_guardando || !_actividadesConAvance.Any())">
                            @if (_guardando)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            💾 Guardar Informe
                        </button>
                        <a href="/informes-diarios/@ProyectoId" class="btn btn-outline-secondary btn-lg">
                            Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public int ProyectoId { get; set; }
    [Parameter] public int? InformeId { get; set; }

    private Proyecto? _proyecto;
    private InformeDiario _informe = new();
    private List<ActividadConAvance> _actividadesConAvance = new();
    private bool _cargando = true;
    private bool _guardando = false;
    private bool _esEdicion => InformeId.HasValue;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _proyecto = await Db.Proyectos.FindAsync(ProyectoId);
            if (_proyecto is null)
            {
                Nav.NavigateTo("/proyectos");
                return;
            }

            if (_esEdicion && InformeId.HasValue)
            {
                var informe = await Db.InformesDiarios
                    .Include(i => i.RegistrosAvance)
                    .FirstOrDefaultAsync(i => i.Id == InformeId.Value);

                if (informe is null)
                {
                    Nav.NavigateTo($"/informes-diarios/{ProyectoId}");
                    return;
                }

                _informe = informe;
                await CargarActividadesConAvanceExistente();
            }
            else
            {
                _informe = new InformeDiario
                {
                    ProyectoId = ProyectoId,
                    Fecha = DateTime.Today,
                    Estado = EstadoInforme.Borrador,
                    Version = "0.a",
                    CreadoPor = "Usuario Actual" // TODO: Obtener del contexto de Identity
                };
                await CargarActividadesNuevas();
            }
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar el formulario: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task CargarActividadesNuevas()
    {
        var actividades = await Db.ActividadesWBS
            .Where(a => a.ProyectoId == ProyectoId && a.Activo)
            .OrderBy(a => a.CodigoWBS)
            .ToListAsync();

        _actividadesConAvance = actividades.Select(act => new ActividadConAvance
        {
            Actividad = act,
            AvanceProgramado = InformeService.CalcularAvanceEsperado(act, _informe.Fecha),
            AvanceReal = 0,
            Desviacion = 0,
            Estado = EstadoAvance.AlDia,
            PersonalEnSitio = 0,
            HorasTrabajadas = 0
        }).ToList();

        // Calcular desviaciones iniciales
        foreach (var item in _actividadesConAvance)
        {
            RecalcularDesviacion(item);
        }
    }

    private async Task CargarActividadesConAvanceExistente()
    {
        var actividades = await Db.ActividadesWBS
            .Where(a => a.ProyectoId == ProyectoId && a.Activo)
            .OrderBy(a => a.CodigoWBS)
            .ToListAsync();

        var registrosExistentes = _informe.RegistrosAvance.ToList();

        _actividadesConAvance = actividades.Select(act =>
        {
            var registroExistente = registrosExistentes.FirstOrDefault(r => r.ActividadWBSId == act.Id);

            return new ActividadConAvance
            {
                Actividad = act,
                AvanceProgramado = InformeService.CalcularAvanceEsperado(act, _informe.Fecha),
                AvanceReal = registroExistente?.PorcentajeAvance ?? 0,
                Desviacion = registroExistente?.Desviacion ?? 0,
                Estado = registroExistente?.Estado ?? EstadoAvance.AlDia,
                PersonalEnSitio = registroExistente?.PersonalEnSitio ?? 0,
                HorasTrabajadas = registroExistente?.HorasTrabajadas ?? 0,
                RegistroExistenteId = registroExistente?.Id
            };
        }).ToList();
    }

    private void RecalcularAvancesProgramados()
    {
        foreach (var item in _actividadesConAvance)
        {
            item.AvanceProgramado = InformeService.CalcularAvanceEsperado(item.Actividad, _informe.Fecha);
            RecalcularDesviacion(item);
        }
    }

    private void RecalcularDesviacion(ActividadConAvance item)
    {
        item.Desviacion = InformeService.CalcularDesviacion(item.AvanceReal, item.AvanceProgramado);
        item.Estado = InformeService.DeterminarEstadoAvance(item.Desviacion);
    }

    private async Task GuardarAsync()
    {
        _guardando = true;
        _error = null;

        try
        {
            // Validar certificado duplicado SOLO si es creación nueva
            if (!_esEdicion)
            {
                var certificadoDuplicado = await Db.InformesDiarios
                    .AnyAsync(i => i.ProyectoId == ProyectoId
                        && i.NumeroCertificado == _informe.NumeroCertificado);

                if (certificadoDuplicado)
                {
                    _error = $"Ya existe un informe con el número de certificado '{_informe.NumeroCertificado}' en este proyecto.";
                    _guardando = false;
                    return;
                }
            }

            if (_esEdicion && InformeId.HasValue)
            {
                // CREAR NUEVA VERSIÓN
                var informeOriginal = await Db.InformesDiarios
                    .AsNoTracking()
                    .FirstOrDefaultAsync(i => i.Id == InformeId.Value);

                if (informeOriginal == null)
                {
                    _error = "No se encontró el informe original.";
                    _guardando = false;
                    return;
                }

                Db.Entry(_informe).State = EntityState.Detached;

                var nuevoInforme = new InformeDiario
                {
                    ProyectoId = _informe.ProyectoId,
                    Fecha = _informe.Fecha,
                    NumeroCertificado = _informe.NumeroCertificado,
                    ResumenActividades = _informe.ResumenActividades,
                    PersonalTotal = _informe.PersonalTotal,
                    Observaciones = _informe.Observaciones,
                    CreadoPor = _informe.CreadoPor,
                    Estado = _informe.Estado,
                    Version = InformeService.SiguienteVersion(informeOriginal.Version),
                    ComentarioCambio = _informe.ComentarioCambio,
                    ComentariosGenerales = _informe.ComentariosGenerales,
                    InformeDiarioAnteriorId = informeOriginal.Id,
                    FechaCreacion = DateTime.UtcNow
                };

                Db.InformesDiarios.Add(nuevoInforme);
                await Db.SaveChangesAsync();

                _informe = nuevoInforme;
            }
            else
            {
                _informe.FechaCreacion = DateTime.UtcNow;
                Db.InformesDiarios.Add(_informe);
                await Db.SaveChangesAsync();
            }

            // Guardar registros de avance desde la tabla
            foreach (var item in _actividadesConAvance)
            {
                var registro = new RegistroAvanceDiario
                {
                    ProyectoId = ProyectoId,
                    ActividadWBSId = item.Actividad.Id,
                    InformeDiarioId = _informe.Id,
                    Fecha = _informe.Fecha,
                    PorcentajeAvance = item.AvanceReal,
                    AvanceEsperado = item.AvanceProgramado,
                    Desviacion = item.Desviacion,
                    Estado = item.Estado,
                    HorasTrabajadas = item.HorasTrabajadas,
                    PersonalEnSitio = item.PersonalEnSitio,
                    ReportadoPor = _informe.CreadoPor,
                    FechaCreacion = DateTime.UtcNow
                };

                // Calcular avance acumulado y días de atraso
                registro.AvanceAcumulado = await InformeService.CalcularAvanceAcumuladoAsync(item.Actividad.Id, _informe.Fecha);
                registro.DiasAtraso = InformeService.CalcularDiasAtraso(item.Actividad, registro.AvanceAcumulado, _informe.Fecha);

                Db.RegistrosAvanceDiario.Add(registro);
            }

            await Db.SaveChangesAsync();

            Nav.NavigateTo($"/informes-diarios/{ProyectoId}");
        }
        catch (Exception ex)
        {
            var detalles = ex.InnerException?.Message ?? ex.Message;
            _error = $"Error al guardar: {detalles}";
            Console.WriteLine($"ERROR COMPLETO: {ex}");
        }
        finally
        {
            _guardando = false;
        }
    }

    private string ObtenerIconoDisciplina(Disciplina disciplina) => disciplina switch
    {
        Disciplina.InicioContrato => "📋",
        Disciplina.EstudiosIngenieria => "📐",
        Disciplina.IngenieriaDetalle => "🔧",
        Disciplina.Suministro => "📦",
        Disciplina.ConstruccionCivil => "🏗️",
        Disciplina.Mecanica => "⚙️",
        Disciplina.Electrica => "⚡",
        Disciplina.Pruebas => "🧪",
        Disciplina.CierreContrato => "✅",
        _ => "📁"
    };

    private string ObtenerIconoEstado(EstadoAvance estado) => estado switch
    {
        EstadoAvance.Adelantado => "🟢",
        EstadoAvance.AlDia => "🟡",
        EstadoAvance.Atrasado => "🔴",
        _ => "⚪"
    };

    private string ObtenerClaseDesviacion(decimal desviacion) => desviacion switch
    {
        > 5 => "bg-success",
        < -5 => "bg-danger",
        _ => "bg-warning text-dark"
    };

    private string ObtenerTextoEstado(EstadoInforme estado) => estado switch
    {
        EstadoInforme.Borrador => "📝 Borrador",
        EstadoInforme.EnRevision => "⏳ En Revisión",
        EstadoInforme.Aprobado => "✅ Aprobado",
        EstadoInforme.Rechazado => "❌ Rechazado",
        EstadoInforme.Anulado => "🚫 Anulado",
        _ => "Desconocido"
    };

    // Clase auxiliar para manejar el estado de cada actividad en la interfaz
    private class ActividadConAvance
    {
        public ActividadWBS Actividad { get; set; } = null!;
        public decimal AvanceProgramado { get; set; }
        public decimal AvanceReal { get; set; }
        public decimal Desviacion { get; set; }
        public EstadoAvance Estado { get; set; }
        public int PersonalEnSitio { get; set; }
        public decimal HorasTrabajadas { get; set; }
        public int? RegistroExistenteId { get; set; }
    }
}
