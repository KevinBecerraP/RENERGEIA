@page "/proyectos/{ProyectoId:int}/costos"
@rendermode InteractiveServer
@inject RenergeIADbContext Db
@inject NavigationManager Nav
@inject CostoService CostoService
@using Microsoft.EntityFrameworkCore
@using RenergeIA.Core.Entities
@using RenergeIA.Infrastructure.Data
@using RenergeIA.Web.Services

<PageTitle>Costos - @(_proyecto?.Nombre ?? "Proyecto") - RenergeIA</PageTitle>

<div class="container-fluid py-4">
    <!-- Encabezado -->
    <div class="row mb-4">
        <div class="col">
            <div class="p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <h2 class="text-white mb-2">
                    <i class="bi bi-cash-coin"></i> Control de Costos
                </h2>
                @if (_proyecto is not null)
                {
                    <p class="text-white mb-0 opacity-90">
                        <strong>@_proyecto.Codigo - @_proyecto.Nombre</strong>
                    </p>
                }
            </div>
        </div>
        <div class="col-auto d-flex align-items-center">
            <a href="/proyectos/@ProyectoId" class="btn btn-light shadow-sm me-2">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
            <button class="btn btn-success shadow-sm" @onclick="CargarPartidasEjemploAsync">
                <i class="bi bi-database-add"></i> Cargar Ejemplo
            </button>
        </div>
    </div>

    @if (_cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Cargando costos...</p>
        </div>
    }
    else if (_proyecto is null)
    {
        <div class="alert alert-warning">
            <strong>⚠️ Proyecto no encontrado</strong>
        </div>
    }
    else
    {
        <!-- Resumen de costos -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body text-center">
                        <i class="bi bi-wallet2 fs-1 text-primary"></i>
                        <h6 class="text-muted mt-2">Total Presupuestado</h6>
                        <h4 class="fw-bold">$@_resumen.TotalPresupuestado.ToString("N0")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body text-center">
                        <i class="bi bi-cart-check fs-1 text-success"></i>
                        <h6 class="text-muted mt-2">Total Ejecutado</h6>
                        <h4 class="fw-bold">$@_resumen.TotalEjecutado.ToString("N0")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body text-center">
                        <i class="bi bi-graph-up fs-1 @(_resumen.Diferencia >= 0 ? "text-success" : "text-danger")"></i>
                        <h6 class="text-muted mt-2">Diferencia</h6>
                        <h4 class="fw-bold @(_resumen.Diferencia >= 0 ? "text-success" : "text-danger")">
                            $@_resumen.Diferencia.ToString("N0")
                        </h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body text-center">
                        <i class="bi bi-percent fs-1 text-info"></i>
                        <h6 class="text-muted mt-2">% Ejecutado</h6>
                        <h4 class="fw-bold">@_resumen.PorcentajeEjecutado.ToString("N1")%</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- Costos por categoría -->
        @if (_categorias.Any())
        {
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow border-0 rounded-4">
                        <div class="card-header p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            <h5 class="mb-0 text-white fw-bold">
                                <i class="bi bi-bar-chart-fill"></i> Costos por Categoría
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Categoría</th>
                                            <th class="text-end">Presupuestado</th>
                                            <th class="text-end">Ejecutado</th>
                                            <th class="text-end">Diferencia</th>
                                            <th class="text-center">% Ejecutado</th>
                                            <th class="text-center">Partidas</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cat in _categorias)
                                        {
                                            <tr>
                                                <td><strong>@cat.Categoria</strong></td>
                                                <td class="text-end">$@cat.Presupuestado.ToString("N0")</td>
                                                <td class="text-end">$@cat.Ejecutado.ToString("N0")</td>
                                                <td class="text-end @(cat.Diferencia >= 0 ? "text-success" : "text-danger")">
                                                    $@cat.Diferencia.ToString("N0")
                                                </td>
                                                <td class="text-center">
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar @(cat.PorcentajeEjecutado > 100 ? "bg-danger" : "bg-success")"
                                                             style="width: @Math.Min(cat.PorcentajeEjecutado, 100)%">
                                                            @cat.PorcentajeEjecutado.ToString("N0")%
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-secondary">@cat.CantidadPartidas</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-dark fw-bold">
                                        <tr>
                                            <td>TOTAL</td>
                                            <td class="text-end">$@_resumen.TotalPresupuestado.ToString("N0")</td>
                                            <td class="text-end">$@_resumen.TotalEjecutado.ToString("N0")</td>
                                            <td class="text-end @(_resumen.Diferencia >= 0 ? "text-success" : "text-danger")">
                                                $@_resumen.Diferencia.ToString("N0")
                                            </td>
                                            <td class="text-center">@_resumen.PorcentajeEjecutado.ToString("N0")%</td>
                                            <td class="text-center">@_resumen.TotalPartidas</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Listado de partidas -->
        <div class="row">
            <div class="col-12">
                <div class="card shadow border-0 rounded-4">
                    <div class="card-header p-4 d-flex justify-content-between align-items-center"
                         style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                        <h5 class="mb-0 text-white fw-bold">
                            <i class="bi bi-list-ul"></i> Partidas Presupuestarias
                        </h5>
                        <a href="/proyectos/@ProyectoId/costos/partidas/crear" class="btn btn-light">
                            <i class="bi bi-plus-circle"></i> Nueva Partida
                        </a>
                    </div>
                    <div class="card-body p-0">
                        @if (!_partidas.Any())
                        {
                            <div class="alert alert-info m-4">
                                <i class="bi bi-info-circle"></i> No hay partidas creadas.
                                <button class="btn btn-link p-0" @onclick="CargarPartidasEjemploAsync">Cargar partidas de ejemplo</button>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Código</th>
                                            <th>Descripción</th>
                                            <th>Categoría</th>
                                            <th class="text-center">Cantidad</th>
                                            <th class="text-center">Unidad</th>
                                            <th class="text-end">Precio Unit.</th>
                                            <th class="text-end">Presupuestado</th>
                                            <th class="text-end">Ejecutado</th>
                                            <th class="text-center">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var partida in _partidas)
                                        {
                                            var totalEjecutado = partida.CostosReales.Sum(c => c.Monto);
                                            <tr>
                                                <td><code>@partida.Codigo</code></td>
                                                <td>@partida.Descripcion</td>
                                                <td><span class="badge bg-primary">@partida.Categoria</span></td>
                                                <td class="text-center">@partida.CantidadPresupuestada.ToString("N2")</td>
                                                <td class="text-center">@partida.Unidad</td>
                                                <td class="text-end">$@partida.PrecioUnitario.ToString("N0")</td>
                                                <td class="text-end fw-bold">$@partida.MontoPresupuestado.ToString("N0")</td>
                                                <td class="text-end">
                                                    <span class="@(totalEjecutado > partida.MontoPresupuestado ? "text-danger" : "text-success")">
                                                        $@totalEjecutado.ToString("N0")
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <a href="/proyectos/@ProyectoId/costos/partidas/@partida.Id/costos"
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-currency-dollar"></i> Costos
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int ProyectoId { get; set; }

    private Proyecto? _proyecto;
    private bool _cargando = true;
    private List<Partida> _partidas = new();
    private ResumenCostos _resumen = new();
    private List<CostoPorCategoria> _categorias = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _proyecto = await Db.Proyectos.FindAsync(ProyectoId);
            if (_proyecto is null) return;

            await CargarDatosAsync();
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task CargarDatosAsync()
    {
        _partidas = await CostoService.ObtenerPartidasConCostosAsync(ProyectoId);
        _resumen = await CostoService.ObtenerResumenCostosAsync(ProyectoId);
        _categorias = await CostoService.ObtenerCostosPorCategoriaAsync(ProyectoId);
    }

    private async Task CargarPartidasEjemploAsync()
    {
        await CostoService.CrearPartidasEjemploAsync(ProyectoId);
        await CargarDatosAsync();
        StateHasChanged();
    }
}
